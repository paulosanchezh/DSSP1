flowchart TD
    A["Inicio: Validar DNI"] --> B["Recibir DNI y limpiar"]
    B --> C["Convertir a mayúsculas"]
    C --> D{¿Longitud == 9?}

    D -->|No| E["❌ Error: Longitud incorrecta"]
    E --> Z["Retornar inválido"]

    D -->|Sí| F["Separar número y letra"]
    F --> G{¿Primeros 8 son dígitos?}

    G -->|No| H["❌ Error: No son dígitos"]
    H --> Z

    G -->|Sí| I{¿Último es letra?}

    I -->|No| J["❌ Error: Último no es letra"]
    J --> Z

    I -->|Sí| K["Convertir número a entero"]
    K --> L["Calcular índice = número % 23"]
    L --> M["Obtener letra correcta de tabla"]
    M --> N{¿Letra == Correcta?}

    N -->|No| O["❌ Error: Letra incorrecta"]
    O --> Z

    N -->|Sí| P["✅ DNI Válido"]
    P --> Z

    Z --> Q["Fin"]

    style A fill:#4CAF50,stroke:#2E7D32,color:#fff
    style E fill:#F44336,stroke:#C62828,color:#fff
    style H fill:#F44336,stroke:#C62828,color:#fff
    style J fill:#F44336,stroke:#C62828,color:#fff
    style O fill:#F44336,stroke:#C62828,color:#fff
    style P fill:#4CAF50,stroke:#2E7D32,color:#fff
    style Q fill:#2196F3,stroke:#1565C0,color:#fff